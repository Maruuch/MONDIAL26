# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token
SHOPIFY_ADMIN_API_KEY=your_admin_api_key
SHOPIFY_ADMIN_API_SECRET=your_admin_api_secret
# Optionnel : si défini, évite l'appel API de résolution dynamique du Publication GID
# Format : gid://shopify/Publication/XXXXXXXXXX
SHOPIFY_ONLINE_STORE_PUBLICATION_ID=

# Printful
PRINTFUL_API_KEY=your_printful_api_key
PRINTFUL_STORE_ID=your_printful_store_id

# n8n
N8N_SECRET=your_n8n_hmac_secret
N8N_BASE_URL=https://your-n8n-instance.com
N8N_WF_A_WEBHOOK_URL=https://your-n8n-instance.com/webhook/wf-a
N8N_WF_B_WEBHOOK_URL=https://your-n8n-instance.com/webhook/wf-b

# Cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# GA4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# App
NEXT_PUBLIC_SITE_URL=https://football2026.com
NEXT_PUBLIC_DISCLAIMER=Produits fan-made non officiels. Non affilié à la FIFA ou aux fédérations nationales.
